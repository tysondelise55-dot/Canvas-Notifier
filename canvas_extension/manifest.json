{
  "manifest_version": 3,
  "name": "Canvas Assistant",
  "version": "1.0",
  "description": "Ask Claude anything about your Canvas assignments",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Canvas Assistant"
  },
  "background": {
    "service_worker": "background.js"
  }
}
